rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Dashboard settings — admin only
    match /dashboard/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'doni@admin.com';
    }
    // Messages — anyone can read, write
    match /messages/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name','text','timestamp']) && request.resource.data.text.size() <= 500;
    }
    // Guestbook — anyone can read, write
    match /guestbook/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name','message','date']);
    }
    // Logs — admin only write, anyone read
    match /logs/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'doni@admin.com';
    }
    // Analytics — admin write, anyone read
    match /analytics/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'doni@admin.com';
    }
    // Presence — anyone write their own, anyone read
    match /presence/{doc} {
      allow read: if true;
      allow write: if true;
    }
    // Polls — anyone read, anyone create/vote
    match /polls/{doc} {
      allow read: if true;
      allow write: if true;
    }
    // URL Shortener — anyone read, anyone create
    match /shorturls/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['url','short','createdAt']);
    }
  }
}