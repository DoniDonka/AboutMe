/**
 * Firestore rules for the MAIN Firebase project: aboutme-8a339
 * (dashboard, contact form, guestbook, admin settings, presence, analytics)
 *
 * Deploy with the Firebase CLI from a directory whose .firebaserc / active
 * project is set to aboutme-8a339:
 *   firebase deploy --only firestore:rules --project aboutme-8a339
 *
 * The CHAT project (doni-dev-dashboard) is a SEPARATE Firebase project and
 * needs its own rules file — see firestore-chat.rules — deployed separately:
 *   firebase deploy --only firestore:rules --project doni-dev-dashboard
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin-only dashboard settings (site title/desc/status/tags/updates note)
    match /dashboard/settings {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'doni@admin.com';
    }

    // Contact form submissions — anyone can submit one, only admin can read/delete
    match /messages/{doc} {
      allow create: if request.resource.data.message is string
                    && request.resource.data.email is string;
      allow read, delete: if request.auth != null && request.auth.token.email == 'doni@admin.com';
    }

    // Guestbook — public signing, admin can moderate
    match /guestbook/{doc} {
      allow read: if true;
      allow create: if request.resource.data.message is string
                    && request.resource.data.message.size() <= 300
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 50;
      allow update, delete: if request.auth != null && request.auth.token.email == 'doni@admin.com';
    }

    // Presence collection for the live visitor counter
    match /presence/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // Analytics (page view counters) — public increment, no auth needed for a view counter
    match /analytics/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
