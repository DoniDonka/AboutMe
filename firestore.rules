rules_version = '2';

// ============================================================
// DONI | DEV - Firestore Security Rules (v3.1 - Firebase Auth)
// ------------------------------------------------------------
// Paste in the Firebase console:
//   Firestore Database -> Rules -> (paste) -> Publish
//
// Requires (one-time setup):
//   1. Firebase console -> Authentication -> Sign-in method ->
//      enable "Email/Password".
//   2. Authentication -> Users -> "Add user" with email
//      donidonka511@gmail.com and a password. That account is the
//      only one allowed to manage data below.
//
// Design:
//  - Public site content (dashboard settings, guestbook, analytics)
//    is readable by everyone so the site renders.
//  - Anyone can submit a contact message or sign the guestbook.
//  - Only the signed-in admin (matching email) can read messages,
//    edit dashboard settings, or delete guestbook/message entries.
//    This is enforced server-side, so it is real protection.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // True only when the request is authenticated as the admin account.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.lower() == 'donidonka511@gmail.com';
    }

    // Dashboard settings: public read (site renders them), admin-only write.
    match /dashboard/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // System deployment logs: the site may append, only admin may read/manage.
    match /logs/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Contact form submissions: anyone may send, only admin may read/manage.
    match /messages/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Guestbook: public read + sign, admin-only edit/delete.
    match /guestbook/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Global visitor analytics counter (public read + increment).
    match /analytics/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // Default deny for anything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
