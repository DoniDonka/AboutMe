/**
 * Firestore rules for the CHAT Firebase project: doni-dev-dashboard
 * (real-time visitor chat + polls)
 *
 * Deploy with the Firebase CLI from a directory whose .firebaserc / active
 * project is set to doni-dev-dashboard:
 *   firebase deploy --only firestore:rules --project doni-dev-dashboard
 *
 * The MAIN site project (aboutme-8a339) has its own separate rules file —
 * see firestore.rules — deployed separately.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Chat messages — public anonymous chat (matches the site's design: no
    // login wall for visitors), with basic shape/size validation on create
    // and reaction-only updates so existing messages can't be rewritten.
    match /messages/{doc} {
      allow read: if true;
      allow create: if request.resource.data.text is string
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 20;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['reactions']);
      allow delete: if request.auth != null && request.auth.token.email == 'doni@admin.com';
    }

    // Polls created via the /poll chat command
    match /polls/{doc} {
      allow read: if true;
      allow create: if request.resource.data.question is string;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['votes', 'voters']); // vote counters only
      allow delete: if request.auth != null && request.auth.token.email == 'doni@admin.com';
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
